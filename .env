# Default environment variables for local development
ENVIRONMENT=dev
BASE_URL=https://parabank.parasoft.com
TEST_TIMEOUT=60000
GLOBAL_TIMEOUT=900000
EXPECT_TIMEOUT=10000
ACTION_TIMEOUT=30000
HEADLESS=true
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
TRACE=on-first-retry
CI_RETRIES=2
LOCAL_RETRIES=0
CI_WORKERS=2
IGNORE_HTTPS=false
LOCALE=en-US
TIMEZONE=America/New_York
PERMISSIONS=geolocation,notifications
BROWSER_ARGS=--disable-infobars,--start-maximized
PROXY=
STORAGE_STATE=
# Optional storage state path for authenticated sessions
# STORAGE_STATE=./src/core/fixtures/storageState.json
